# =============================================================================
# OpenClaw – Umgebungsvariablen
# DIESE DATEI KOPIEREN nach .env und mit echten Werten befüllen!
#   cp .env.example .env
#   chmod 600 .env
# Die .env-Datei wird NICHT in Git eingecheckt (.gitignore).
# =============================================================================

# ── Claude API (Anthropic) ───────────────────────────────────────────────────
# Erhältlich unter: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-DEIN_KEY_HIER

# ── Telegram Bot ─────────────────────────────────────────────────────────────
# 1. Telegram öffnen → @BotFather suchen
# 2. /newbot → Name vergeben → Token kopieren
TELEGRAM_BOT_TOKEN=1234567890:DEIN_BOT_TOKEN_HIER

# Nur diese User-IDs dürfen mit dem Bot reden (kommagetrennt)
# Deine ID findest du über @userinfobot auf Telegram
TELEGRAM_ALLOWED_USERS=123456789

# ── Tailscale ────────────────────────────────────────────────────────────────
# Auth-Key für den ersten Container-Start (einmalig nötig)
# Erstellen unter: https://login.tailscale.com/admin/settings/keys
# Empfehlung: "Ephemeral" DEAKTIVIEREN, "Reusable" AKTIVIEREN
TS_AUTHKEY=tskey-auth-DEIN_KEY_HIER
