{
  "agents": {
    "defaults": {
      "model": {
        "primary": "ollama/gemma4:e4b"
      },
      "workspace": "/home/openclaw/.openclaw/workspace"
    }
  },
  "gateway": {
    "port": 18789,
    "bind": "lan",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    }
  },
  "channels": {
    "telegram": {
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "allowlist",
      "allowFrom": ["${TELEGRAM_ALLOWED_USERS}"]
    }
  },
  "diagnostics": {
    "enabled": false
  }
}
